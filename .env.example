DATABASE_URL="postgresql://user:pass@localhost:5432/coachplan"

# Clerk (required for authenticated flows)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_replace_me"
CLERK_SECRET_KEY="sk_test_replace_me"

# Optional AI parsing provider settings
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"

# Required for OAuth state HMAC signing (generate with: openssl rand -base64 32)
INTEGRATIONS_STATE_SECRET=""

# Optional: Sentry error tracking (get DSN from sentry.io)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Optional Strava integration
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_WEBHOOK_VERIFY_TOKEN=""
# Optional: set to your Strava webhook subscription ID to reject spoofed events
STRAVA_WEBHOOK_SUBSCRIPTION_ID=""
